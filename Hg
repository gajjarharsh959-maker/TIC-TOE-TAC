name: Build Android APK
on: [push, pull_request]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Build Love Android APK
        uses: love-actions/love-actions-android@v2
        with:
          app-name: "My Awesome Game"
          bundle-id: "com.yourname.mygame"
          love-ref: "11.5" # Match this to your LÖVE version
          # If your files are in the root, leave this as "."
          # If you have a .love file already, use: love-package: "game.love"
          
      - name: Upload APK Artifact
        uses: actions/upload-artifact@v4
        with:
          name: my-game-apk
          path: "**/*.apk"
